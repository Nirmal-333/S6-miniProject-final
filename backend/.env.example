# ─── BACKEND ENVIRONMENT VARIABLES ───────────────────────────────────────────
#
# Database: Supabase (PostgreSQL)
# Get credentials from: https://supabase.com → Project Settings → Database
#

# Supabase PostgreSQL host (found in Project Settings → Database)
DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co

# PostgreSQL port (always 5432 for Supabase)
DB_PORT=5432

# Database user (default: postgres)
DB_USER=postgres

# Your Supabase database password (set during project creation)
DB_PASSWORD=your_supabase_db_password

# Database name (default: postgres)
DB_NAME=postgres

# Enable SSL (required for Supabase — set to false only for local pg without SSL)
DB_SSL=true

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT Secret — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_key_in_production

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# Environment: development | production
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allowed frontend origin
# - Local:      http://localhost:3000
# - Production: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:3000
